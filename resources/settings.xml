<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>
    <setting type="lsep" label="WireGuard Switcher" />
    <setting id="next_server" type="action" label="Nächsten VPN-Server aktivieren"
              action="RunScript(service.wireguard.switcher,next)" />
    <setting id="show_status" type="action" label="Verbindungsstatus anzeigen"
              action="RunScript(service.wireguard.switcher,status)" />
    <setting id="map_button" type="action" label="Remote-Taste belegen"
              action="RunScript(service.wireguard.switcher,learn)" />
    <setting type="sep" />
    <setting id="kill_switch" type="bool" label="Kill Switch (kein Internet ohne VPN)"
              default="false" />
</settings>
