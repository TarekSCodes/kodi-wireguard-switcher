<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.wireguard.switcher"
       name="WireGuard Switcher"
       version="0.9.0"
       provider-name="local">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.service" library="service.py" start="login"/>
    <extension point="xbmc.python.script" library="switch.py"/>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">WireGuard VPN Server Switcher</summary>
        <description lang="en_GB">
            Restores the last active WireGuard server on Kodi startup and
            cycles through HideMe WireGuard configs on remote button press.
        </description>
        <platform>linux</platform>
    </extension>
</addon>
